#! @PYTHON@
#
from cdoTest import *
#
FORMAT="-f srv -b 32"
#
OPERATORS=["eca_hwfi","etccdi_wsdi"]
#
IFILE1=f'{DATAPATH}/tsurf_1d_1year'
IFILE2=f'{DATAPATH}/tsurf_runpctl_1d_1year'
#
test_module = TestModule()
#
for OPER in OPERATORS:
        RFILE=f'{DATAPATH}{OPER}_ref'
        OFILE=f'{OPER}_res'

        t = TAPTest(OPER)
        t.add(f'{CDO} {FORMAT} {OPER} {IFILE1} {IFILE2} {OFILE}')
        t.add(f'{CDO} diff,abslim=0.0 {OFILE} {RFILE}')
        t.clean(OFILE)
        test_module.add(t)

test_module.run()
