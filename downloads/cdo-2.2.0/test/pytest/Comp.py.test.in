#! @PYTHON@
from cdoTest import *

FORMAT="-f srv -b 32"
OPERATORS=["eq", "ne", "le", "lt", "ge", "gt"]
CONST=300
#
IFILE=f'{DATAPATH}comptest.srv'
CFILE="constdata"

test_module = TestModule()
test_module.prepare(f'{CDO} {FORMAT} const,{CONST},{IFILE} {CFILE}')
for OPER in OPERATORS:
    RFILE=f'{DATAPATH}comp_{OPER}c_ref'
    OFILE=f'comp_{OPER}_res'

    t = TAPTest(OPER)
    t.add(f'{CDO} {FORMAT} {OPER} {IFILE} {CFILE} {OFILE}')
    t.add(f'{CDO} diff {OFILE} {RFILE}')
    t.clean(OFILE)
    test_module.add(t)

test_module.clean(CFILE)
test_module.run()


